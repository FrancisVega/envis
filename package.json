{
  "name": "@hiscovega/envis",
  "version": "0.3.0",
  "description": "Pequeño dashboard web para gestionar ficheros .env: activar/desactivar, editar, perfiles y comparar.",
  "keywords": [
    "env",
    "dotenv",
    "environment-variables",
    "cli",
    "dashboard",
    "dx",
    "config"
  ],
  "author": "hisco",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrancisVega/envis.git"
  },
  "homepage": "https://github.com/FrancisVega/envis#readme",
  "bugs": "https://github.com/FrancisVega/envis/issues",
  "type": "module",
  "bin": {
    "envis": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/dev.ts",
    "dev:web": "vite",
    "build": "tsup && vite build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.web.json --noEmit",
    "prepublishOnly": "npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25",
    "open": "^11.0.0"
  }
}
